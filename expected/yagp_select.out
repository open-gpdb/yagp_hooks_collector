CREATE EXTENSION yagp_hooks_collector;
CREATE OR REPLACE FUNCTION yagp_status_order(status text)
RETURNS integer
AS $$
BEGIN
    RETURN CASE status
        WHEN 'QUERY_STATUS_SUBMIT' THEN 1
        WHEN 'QUERY_STATUS_START' THEN 2
        WHEN 'QUERY_STATUS_END' THEN 3
        WHEN 'QUERY_STATUS_DONE' THEN 4
        ELSE 999
    END;
END;
$$ LANGUAGE plpgsql IMMUTABLE;
SET yagpcc.enable TO TRUE;
SET yagpcc.report_nested_queries TO TRUE;
-- Basic SELECT tests
SET yagpcc.log_to_table TO TRUE;
SELECT 1;
 ?column? 
----------
        1
(1 row)

SELECT COUNT(*) FROM generate_series(1,10);
 count 
-------
    10
(1 row)

SET yagpcc.log_to_table TO FALSE;
SELECT dbid, ccnt, query_text, query_status FROM yagp_log ORDER BY dbid, ccnt, yagp_status_order(query_status) ASC;
 dbid | ccnt |                 query_text                  |    query_status     
------+------+---------------------------------------------+---------------------
    1 |    9 | SELECT 1;                                   | QUERY_STATUS_SUBMIT
    1 |    9 |                                             | QUERY_STATUS_START
    1 |    9 |                                             | QUERY_STATUS_END
    1 |    9 |                                             | QUERY_STATUS_DONE
    1 |   11 | SELECT COUNT(*) FROM generate_series(1,10); | QUERY_STATUS_SUBMIT
    1 |   11 |                                             | QUERY_STATUS_START
    1 |   11 |                                             | QUERY_STATUS_END
    1 |   11 |                                             | QUERY_STATUS_DONE
(8 rows)

SELECT yagp_truncate_log() IS NOT NULL AS t;
 t 
---
 t
(1 row)

-- Transaction test
SET yagpcc.log_to_table TO TRUE;
BEGIN;
SELECT 1;
 ?column? 
----------
        1
(1 row)

COMMIT;
SET yagpcc.log_to_table TO FALSE;
SELECT dbid, ccnt, query_text, query_status FROM yagp_log ORDER BY dbid, ccnt, yagp_status_order(query_status) ASC;
 dbid | ccnt | query_text |    query_status     
------+------+------------+---------------------
    1 |   22 | SELECT 1;  | QUERY_STATUS_SUBMIT
    1 |   22 |            | QUERY_STATUS_START
    1 |   22 |            | QUERY_STATUS_END
    1 |   22 |            | QUERY_STATUS_DONE
(4 rows)

SELECT yagp_truncate_log() IS NOT NULL AS t;
 t 
---
 t
(1 row)

-- CTE test
SET yagpcc.log_to_table TO TRUE;
WITH t AS (VALUES (1), (2))
SELECT * FROM t;
 column1 
---------
       1
       2
(2 rows)

SET yagpcc.log_to_table TO FALSE;
SELECT dbid, ccnt, query_text, query_status FROM yagp_log ORDER BY dbid, ccnt, yagp_status_order(query_status) ASC;
 dbid | ccnt |         query_text          |    query_status     
------+------+-----------------------------+---------------------
    1 |   33 | WITH t AS (VALUES (1), (2))+| QUERY_STATUS_SUBMIT
      |      | SELECT * FROM t;            | 
    1 |   33 |                             | QUERY_STATUS_START
    1 |   33 |                             | QUERY_STATUS_END
    1 |   33 |                             | QUERY_STATUS_DONE
(4 rows)

SELECT yagp_truncate_log() IS NOT NULL AS t;
 t 
---
 t
(1 row)

-- Prepared statement test
SET yagpcc.log_to_table TO TRUE;
PREPARE test_stmt AS SELECT 1;
EXECUTE test_stmt;
 ?column? 
----------
        1
(1 row)

DEALLOCATE test_stmt;
SET yagpcc.log_to_table TO FALSE;
SELECT dbid, ccnt, query_text, query_status FROM yagp_log ORDER BY dbid, ccnt, yagp_status_order(query_status) ASC;
 dbid | ccnt |           query_text           |    query_status     
------+------+--------------------------------+---------------------
    1 |   44 | PREPARE test_stmt AS SELECT 1; | QUERY_STATUS_SUBMIT
    1 |   44 |                                | QUERY_STATUS_START
    1 |   44 |                                | QUERY_STATUS_END
    1 |   44 |                                | QUERY_STATUS_DONE
(4 rows)

SELECT yagp_truncate_log() IS NOT NULL AS t;
 t 
---
 t
(1 row)

DROP FUNCTION yagp_status_order(text);
DROP EXTENSION yagp_hooks_collector;
